{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mari",
  "version": "0.1.2",
  "identifier": "com.mari.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mari",
        "width": 1040,
        "height": 760,
        "minWidth": 640,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4NDkxOEI1MTFFNUNBMjQKUldRa3l1VVJ0UmhKNkhPcFpZUml1MERJWmc5WXRTanFLb0YxcDFvSjNKZ1c3QUdyTDFLVkhUK0sK",
      "endpoints": [
        "https://github.com/j8ckfi/Mari/releases/latest/download/latest.json"
      ]
    }
  }
}
